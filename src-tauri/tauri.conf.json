{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Controle de Brilho",
  "version": "0.1.0",
  "identifier": "com.eduardo.controledebrilho",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Controle de Brilho",
        "width": 320,
        "height": 440,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true,
        "visible": true
      },
      {
        "label": "osd",
        "title": "Brilho",
        "width": 260,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installMode": "perMachine",
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false
      }
    }
  }
}